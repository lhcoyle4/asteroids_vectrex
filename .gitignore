# ─────────────────────────────────────────────────
#  FULIGIN — .gitignore
#  C / MinGW-w64 / SDL2 project on Windows
# ─────────────────────────────────────────────────

# ── Compiled output ──────────────────────────────
*.exe
*.o
*.a
*.dll
*.so
*.dylib

# ── Build artifacts ──────────────────────────────
*.obj
*.map
*.pdb
*.ilk
*.exp
*.lib
*.ncb
*.suo
*.user
*.sdf

# ── Temporary / scratch files ────────────────────
_tmp_*.c
*.c.bak
*.bak

# ── Runtime data ─────────────────────────────────
highscores.dat

# ── Thirdparty binaries (SDL2, SDL2_mixer) ───────
thirdparty/SDL2-*/i686-w64-mingw32/bin/
thirdparty/SDL2-*/i686-w64-mingw32/lib/
thirdparty/SDL2-*/x86_64-w64-mingw32/bin/
thirdparty/SDL2-*/x86_64-w64-mingw32/lib/
thirdparty/SDL2_mixer-*/i686-w64-mingw32/bin/
thirdparty/SDL2_mixer-*/i686-w64-mingw32/lib/
thirdparty/SDL2_mixer-*/x86_64-w64-mingw32/bin/
thirdparty/SDL2_mixer-*/x86_64-w64-mingw32/lib/

# ── Windows helper/dev scripts (not for repo) ────
do_*.bat

# ── OS / editor noise ────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/
